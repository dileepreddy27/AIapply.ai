# Backend env (Render / local API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.vercel.app
# Optional regex for dynamic preview domains (Vercel, etc.)
CORS_ORIGIN_REGEX=^https://[a-zA-Z0-9-]+\.vercel\.app$
GOOGLE_FORM_ROLES_CSV_URL=
LIVE_GREENHOUSE_BOARDS=openai,anthropic,mistral,vercel,retool
LIVE_LEVER_SITES=lever,n8n
RESEND_API_KEY=
EMAIL_FROM=AIapply.ai <onboarding@yourdomain.com>
AUTO_APPLY_CRON_SECRET=

# Optional LLM integrations
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
