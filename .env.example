# Backend env (Render / local API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.vercel.app
# Optional regex for dynamic preview domains (Vercel, etc.)
CORS_ORIGIN_REGEX=^https://[a-zA-Z0-9-]+\.vercel\.app$
GOOGLE_FORM_ROLES_CSV_URL=
LIVE_GREENHOUSE_BOARDS=vercel,stripe,datadog,scaleai,fivetran,robinhood,brex,airtable,discord,webflow,dropbox,checkr,asana,cloudflare,yugabyte,samsara,headway,growtherapy,transcarent
LIVE_LEVER_SITES=palantir,Flex,rhombus-systems,integrate,ifm-us,disqo,finix,hhaexchange,artera,revealtech,Ketch,getsquire,acceldata,sugarcrm,upguard,propelsoftware,bolster,onit,entrata,Versana,binance,afero,Way,versapay,Nexos,analyticpartners,weInfuse,qualysoft,syw.com,RyzLabs,hive
RESEND_API_KEY=
EMAIL_FROM=AIapply.ai <onboarding@yourdomain.com>
AUTO_APPLY_CRON_SECRET=
ASSISTANT_PROVIDER=auto
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional LLM integrations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=
